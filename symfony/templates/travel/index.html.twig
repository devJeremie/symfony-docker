{% extends 'base.html.twig' %}
{% block title %}Voyages - TravelDock{% endblock %}

{% block body %}
<div class="mx-auto max-w-7xl px-5 sm:px-8 py-10">

  <!-- Header -->
  <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
    <div>
      <span class="text-amber font-semibold text-sm uppercase tracking-[0.18em]">Catalogue</span>
      <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mt-1">Tous les voyages</h1>
    </div>
    <a href="{{ path('travel_new') }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-forest text-white font-semibold shadow-soft hover:bg-forestdk transition-colors text-[15px]">
      <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"></path></svg>
      Nouveau voyage
    </a>
  </div>

  {% if travels is empty %}
    <div class="flex flex-col items-center justify-center py-16 text-center bg-forestlt/30 rounded-3xl border border-forestlt">
      <svg viewBox="0 0 24 24" class="w-10 h-10 text-forest/40 mb-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
      <p class="text-forestdk/60 text-[15px]">Aucun voyage pour le moment.</p>
    </div>
  {% else %}

  <!-- Table -->
  <div class="bg-white rounded-3xl shadow-soft border border-forestlt overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-[14px]">
        <thead>
          <tr class="bg-forestlt/60 text-forestdk/70 text-xs font-semibold uppercase tracking-wide">
            <th class="px-5 py-4 text-left">Titre</th>
            <th class="px-5 py-4 text-left">Destination</th>
            <th class="px-5 py-4 text-left">Départ</th>
            <th class="px-5 py-4 text-left">Retour</th>
            <th class="px-5 py-4 text-right">Prix</th>
            <th class="px-5 py-4 text-center">Places</th>
            <th class="px-5 py-4 text-center">Statut</th>
            <th class="px-5 py-4 text-center">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-forestlt">
          {% for travel in travels %}
          <tr class="hover:bg-forestlt/20 transition-colors">
            <td class="px-5 py-4 font-semibold text-forestdk">{{ travel.title }}</td>
            <td class="px-5 py-4 text-forestdk/70">{{ travel.destination }}</td>
            <td class="px-5 py-4 text-forestdk/70">{{ travel.departureDate|date('d/m/Y') }}</td>
            <td class="px-5 py-4 text-forestdk/70">{{ travel.returnDate|date('d/m/Y') }}</td>
            <td class="px-5 py-4 text-right font-semibold text-forest">{{ travel.price }} €</td>
            <td class="px-5 py-4 text-center">
              <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold
                {% if travel.availableSeats > 5 %}bg-forest/15 text-forest
                {% elseif travel.availableSeats > 0 %}bg-amberlt text-amber
                {% else %}bg-red-100 text-red-600{% endif %}">
                {{ travel.availableSeats }}
              </span>
            </td>
            <td class="px-5 py-4 text-center">
              <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold
                {% if travel.status == 'published' %}bg-forest/15 text-forest
                {% elseif travel.status == 'draft' %}bg-forestlt text-forestdk/60
                {% else %}bg-red-100 text-red-600{% endif %}">
                {% if travel.status == 'published' %}Publié
                {% elseif travel.status == 'draft' %}Brouillon
                {% else %}Annulé{% endif %}
              </span>
            </td>
            <td class="px-5 py-4">
              <div class="flex items-center justify-center gap-2">
                <a href="{{ path('travel_show', {id: travel.id}) }}" title="Voir" class="grid place-items-center w-8 h-8 rounded-xl bg-forestlt text-forest hover:bg-forest hover:text-white transition-colors">
                  <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                </a>
                <a href="{{ path('travel_edit', {id: travel.id}) }}" title="Modifier" class="grid place-items-center w-8 h-8 rounded-xl bg-amberlt text-amber hover:bg-amber hover:text-white transition-colors">
                  <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                </a>
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endif %}

</div>
{% endblock %}
