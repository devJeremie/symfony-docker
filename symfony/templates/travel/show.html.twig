{% extends 'base.html.twig' %}
{% block title %}{{ travel.title }} - TravelDock{% endblock %}

{% block body %}
<div class="mx-auto max-w-7xl px-5 sm:px-8 py-10">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-forestdk/50 mb-8">
    <a href="{{ path('app_home') }}" class="hover:text-forest transition-colors">Accueil</a>
    <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"></path></svg>
    <a href="{{ path('travel_index') }}" class="hover:text-forest transition-colors">Voyages</a>
    <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"></path></svg>
    <span class="text-forestdk font-medium truncate max-w-[200px]">{{ travel.title }}</span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

    <!-- Main content -->
    <div class="lg:col-span-2 space-y-6">

      <!-- Title block -->
      <div>
        <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold mb-3
          {% if travel.status == 'published' %}bg-forest/15 text-forest
          {% elseif travel.status == 'draft' %}bg-forestlt text-forestdk/60
          {% else %}bg-red-100 text-red-600{% endif %}">
          {% if travel.status == 'published' %}Publié{% elseif travel.status == 'draft' %}Brouillon{% else %}Annulé{% endif %}
        </span>
        <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-tight">{{ travel.title }}</h1>
        <a href="{{ path('destination_show', {id: travel.destination.id}) }}" class="inline-flex items-center gap-1.5 mt-2 text-forest font-medium hover:underline">
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          {{ travel.destination }}
        </a>
      </div>

      <!-- Stats grid -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="bg-white rounded-2xl border border-forestlt p-4 text-center shadow-soft">
          <svg viewBox="0 0 24 24" class="w-6 h-6 text-forest mx-auto mb-2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
          <p class="text-xs text-forestdk/50 mb-0.5">Départ</p>
          <p class="font-semibold text-forestdk text-sm">{{ travel.departureDate|date('d/m/Y') }}</p>
        </div>
        <div class="bg-white rounded-2xl border border-forestlt p-4 text-center shadow-soft">
          <svg viewBox="0 0 24 24" class="w-6 h-6 text-forest mx-auto mb-2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
          <p class="text-xs text-forestdk/50 mb-0.5">Retour</p>
          <p class="font-semibold text-forestdk text-sm">{{ travel.returnDate|date('d/m/Y') }}</p>
        </div>
        <div class="bg-white rounded-2xl border border-forestlt p-4 text-center shadow-soft">
          <svg viewBox="0 0 24 24" class="w-6 h-6 text-amber mx-auto mb-2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
          <p class="text-xs text-forestdk/50 mb-0.5">Durée</p>
          <p class="font-semibold text-forestdk text-sm">{{ travel.duration }} jours</p>
        </div>
        <div class="bg-white rounded-2xl border border-forestlt p-4 text-center shadow-soft">
          <svg viewBox="0 0 24 24" class="w-6 h-6 text-amber mx-auto mb-2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 00-3-3.87"></path></svg>
          <p class="text-xs text-forestdk/50 mb-0.5">Places restantes</p>
          <p class="font-semibold text-forestdk text-sm">{{ travel.availableSeats }} / {{ travel.maxParticipants }}</p>
        </div>
      </div>

      <!-- Description -->
      {% if travel.description %}
      <div class="bg-white rounded-3xl border border-forestlt shadow-soft p-6">
        <h2 class="font-display text-lg font-bold mb-3">Description</h2>
        <p class="text-forestdk/75 leading-relaxed">{{ travel.description }}</p>
      </div>
      {% endif %}

      <!-- Actions -->
      <div class="flex flex-wrap gap-3 pt-2">
        <a href="{{ path('travel_edit', {id: travel.id}) }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-amber text-white font-semibold hover:bg-[#a4660f] transition-colors text-[15px]">
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
          Modifier
        </a>
        <form action="{{ path('travel_delete', {id: travel.id}) }}" method="post" onsubmit="return confirm('Supprimer ce voyage définitivement ?')">
          <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ travel.id) }}">
          <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-red-500 text-white font-semibold hover:bg-red-600 transition-colors text-[15px]">
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14H6L5 6"></path><path d="M10 11v6M14 11v6M9 6V4h6v2"></path></svg>
            Supprimer
          </button>
        </form>
        <a href="{{ path('travel_index') }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-forestlt text-forestdk font-semibold hover:bg-forestlt transition-colors text-[15px]">
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"></path></svg>
          Retour
        </a>
      </div>
    </div>

    <!-- Sidebar: booking card -->
    <div class="space-y-6">
      <div class="bg-white rounded-3xl border-2 border-forest shadow-lift p-6 sticky top-24">
        <p class="text-xs text-forestdk/45 font-semibold uppercase tracking-wide mb-1">À partir de</p>
        <p class="font-display text-4xl font-bold text-forest leading-none mb-0.5">
          {{ travel.price }}€
        </p>
        <p class="text-sm text-forestdk/50 mb-6">par personne</p>

        <div class="space-y-2.5 text-[14px] text-forestdk/70 mb-6 pb-6 border-b border-forestlt">
          <div class="flex justify-between">
            <span>Départ</span>
            <span class="font-medium text-forestdk">{{ travel.departureDate|date('d/m/Y') }}</span>
          </div>
          <div class="flex justify-between">
            <span>Retour</span>
            <span class="font-medium text-forestdk">{{ travel.returnDate|date('d/m/Y') }}</span>
          </div>
          <div class="flex justify-between">
            <span>Durée</span>
            <span class="font-medium text-forestdk">{{ travel.duration }} jours</span>
          </div>
          <div class="flex justify-between">
            <span>Places dispo.</span>
            <span class="font-medium {% if travel.availableSeats == 0 %}text-red-500{% else %}text-forest{% endif %}">
              {{ travel.availableSeats }}
            </span>
          </div>
        </div>

        {% if travel.availableSeats > 0 %}
          <a href="{{ path('booking_new', {id: travel.id}) }}" class="flex items-center justify-center gap-2 w-full px-6 py-3.5 rounded-full bg-amber text-white font-semibold text-[16px] shadow-lift hover:bg-[#a4660f] transition-colors">
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
            Réserver maintenant
          </a>
        {% else %}
          <button disabled class="flex items-center justify-center w-full px-6 py-3.5 rounded-full bg-forestlt text-forestdk/40 font-semibold text-[16px] cursor-not-allowed">
            Complet
          </button>
        {% endif %}
      </div>
    </div>

  </div>
</div>
{% endblock %}
