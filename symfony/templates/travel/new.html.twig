{% extends 'base.html.twig' %}
{% block title %}Nouveau voyage - TravelDock{% endblock %}

{% block body %}
<div class="mx-auto max-w-3xl px-5 sm:px-8 py-10">

  <!-- Header -->
  <div class="mb-8">
    <span class="text-amber font-semibold text-sm uppercase tracking-[0.18em]">Catalogue</span>
    <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mt-1">Nouveau voyage</h1>
  </div>

  <div class="bg-white rounded-3xl shadow-soft border border-forestlt p-6 sm:p-8">
    <form action="{{ path('travel_new') }}" method="post" class="space-y-5">

      <div>
        <label for="title" class="block text-sm font-semibold text-forestdk/70 mb-1.5">
          Titre du voyage <span class="text-red-400">*</span>
        </label>
        <input type="text" id="title" name="title" required
               value="{{ travel.title ?? '' }}"
               placeholder="Ex : Découverte du Japon"
               class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk placeholder:text-forestdk/35 focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px]">
      </div>

      <div>
        <label for="destination" class="block text-sm font-semibold text-forestdk/70 mb-1.5">
          Destination <span class="text-red-400">*</span>
        </label>
        <select id="destination" name="destination" required
                class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px] cursor-pointer">
          <option value="">— Choisir une destination —</option>
          {% for dest in destinations %}
            <option value="{{ dest.id }}">{{ dest }}</option>
          {% endfor %}
        </select>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="departureDate" class="block text-sm font-semibold text-forestdk/70 mb-1.5">
            Date de départ <span class="text-red-400">*</span>
          </label>
          <input type="date" id="departureDate" name="departureDate" required
                 class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px]">
        </div>
        <div>
          <label for="returnDate" class="block text-sm font-semibold text-forestdk/70 mb-1.5">
            Date de retour <span class="text-red-400">*</span>
          </label>
          <input type="date" id="returnDate" name="returnDate" required
                 class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px]">
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="price" class="block text-sm font-semibold text-forestdk/70 mb-1.5">
            Prix par personne (€) <span class="text-red-400">*</span>
          </label>
          <input type="number" id="price" name="price" required min="1" step="0.01"
                 placeholder="1 299.00"
                 class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk placeholder:text-forestdk/35 focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px]">
        </div>
        <div>
          <label for="maxParticipants" class="block text-sm font-semibold text-forestdk/70 mb-1.5">
            Participants max <span class="text-red-400">*</span>
          </label>
          <input type="number" id="maxParticipants" name="maxParticipants" required min="1"
                 placeholder="20"
                 class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk placeholder:text-forestdk/35 focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px]">
        </div>
      </div>

      <div>
        <label for="description" class="block text-sm font-semibold text-forestdk/70 mb-1.5">Description</label>
        <textarea id="description" name="description" rows="4"
                  placeholder="Décrivez ce voyage..."
                  class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk placeholder:text-forestdk/35 focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px] resize-none">{{ travel.description ?? '' }}</textarea>
      </div>

      <div>
        <label for="status" class="block text-sm font-semibold text-forestdk/70 mb-1.5">Statut</label>
        <select id="status" name="status"
                class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px] cursor-pointer">
          <option value="draft">Brouillon</option>
          <option value="published">Publié</option>
        </select>
      </div>

      <div class="flex flex-wrap gap-3 pt-2">
        <button type="submit" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-forest text-white font-semibold shadow-soft hover:bg-forestdk transition-colors text-[15px]">
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          Créer le voyage
        </button>
        <a href="{{ path('travel_index') }}" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-forestlt text-forestdk font-semibold hover:bg-forestlt transition-colors text-[15px]">
          Annuler
        </a>
      </div>

    </form>
  </div>
</div>
{% endblock %}
