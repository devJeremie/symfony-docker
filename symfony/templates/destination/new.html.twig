{% extends 'base.html.twig' %}
{% block title %}Nouvelle destination - TravelDock{% endblock %}

{% block body %}
<div class="mx-auto max-w-3xl px-5 sm:px-8 py-10">

  <div class="mb-8">
    <span class="text-amber font-semibold text-sm uppercase tracking-[0.18em]">Carte du monde</span>
    <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mt-1">Nouvelle destination</h1>
  </div>

  <div class="bg-white rounded-3xl shadow-soft border border-forestlt p-6 sm:p-8">
    <form action="{{ path('destination_new') }}" method="post" class="space-y-5">

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="name" class="block text-sm font-semibold text-forestdk/70 mb-1.5">
            Nom <span class="text-red-400">*</span>
          </label>
          <input type="text" id="name" name="name" required placeholder="Ex : Tokyo"
                 class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk placeholder:text-forestdk/35 focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px]">
        </div>
        <div>
          <label for="country" class="block text-sm font-semibold text-forestdk/70 mb-1.5">
            Pays <span class="text-red-400">*</span>
          </label>
          <input type="text" id="country" name="country" required placeholder="Ex : Japon"
                 class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk placeholder:text-forestdk/35 focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px]">
        </div>
      </div>

      <div>
        <label for="iataCode" class="block text-sm font-semibold text-forestdk/70 mb-1.5">Code IATA (aéroport)</label>
        <input type="text" id="iataCode" name="iataCode" maxlength="10" placeholder="Ex : NRT"
               class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk placeholder:text-forestdk/35 focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px] font-mono uppercase">
        <p class="mt-1.5 text-xs text-forestdk/40">Code de l'aéroport principal (optionnel)</p>
      </div>

      <div>
        <label for="description" class="block text-sm font-semibold text-forestdk/70 mb-1.5">Description</label>
        <textarea id="description" name="description" rows="4"
                  placeholder="Décrivez cette destination..."
                  class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk placeholder:text-forestdk/35 focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px] resize-none"></textarea>
      </div>

      <div class="flex flex-wrap gap-3 pt-2">
        <button type="submit" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-forest text-white font-semibold shadow-soft hover:bg-forestdk transition-colors text-[15px]">
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          Créer la destination
        </button>
        <a href="{{ path('destination_index') }}" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-forestlt text-forestdk font-semibold hover:bg-forestlt transition-colors text-[15px]">
          Annuler
        </a>
      </div>

    </form>
  </div>
</div>
{% endblock %}
