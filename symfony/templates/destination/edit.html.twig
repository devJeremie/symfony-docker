{% extends 'base.html.twig' %}
{% block title %}Modifier {{ destination.name }} - TravelDock{% endblock %}

{% block body %}
<div class="mx-auto max-w-3xl px-5 sm:px-8 py-10">

  <div class="mb-8">
    <span class="text-amber font-semibold text-sm uppercase tracking-[0.18em]">Carte du monde</span>
    <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mt-1">Modifier la destination</h1>
    <p class="mt-1 text-forestdk/55 text-[15px]">{{ destination.name }}, {{ destination.country }}</p>
  </div>

  <div class="bg-white rounded-3xl shadow-soft border border-forestlt p-6 sm:p-8">
    <form action="{{ path('destination_edit', {id: destination.id}) }}" method="post" enctype="multipart/form-data" class="space-y-5">

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="name" class="block text-sm font-semibold text-forestdk/70 mb-1.5">
            Nom <span class="text-red-400">*</span>
          </label>
          <input type="text" id="name" name="name" required value="{{ destination.name }}"
                 class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px]">
        </div>
        <div>
          <label for="country" class="block text-sm font-semibold text-forestdk/70 mb-1.5">
            Pays <span class="text-red-400">*</span>
          </label>
          <input type="text" id="country" name="country" required value="{{ destination.country }}"
                 class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px]">
        </div>
      </div>

      <div>
        <label for="iataCode" class="block text-sm font-semibold text-forestdk/70 mb-1.5">Code IATA</label>
        <input type="text" id="iataCode" name="iataCode" value="{{ destination.iataCode }}"
               class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px] font-mono uppercase">
      </div>

      <div>
        <label for="description" class="block text-sm font-semibold text-forestdk/70 mb-1.5">Description</label>
        <textarea id="description" name="description" rows="4"
                  class="w-full px-4 py-3 rounded-2xl border border-forestlt bg-white text-forestdk focus:outline-none focus:ring-2 focus:ring-forest/25 focus:border-forest transition text-[15px] resize-none">{{ destination.description }}</textarea>
      </div>

      <!-- Image -->
      <div>
        <label class="block text-sm font-semibold text-forestdk/70 mb-1.5">Image de la destination</label>

        {% if destination.imageName %}
        <div class="mb-3 relative w-full h-44 rounded-2xl overflow-hidden border border-forestlt">
          <img src="{{ asset('images/destinations/' ~ destination.imageName) }}"
               alt="{{ destination.name }}"
               class="w-full h-full object-cover">
          <span class="absolute top-2 left-2 px-2 py-1 rounded-full bg-forest/80 text-white text-xs font-medium backdrop-blur-sm">Image actuelle</span>
        </div>
        {% else %}
        <div class="mb-3 w-full h-44 rounded-2xl border-2 border-dashed border-forestlt flex items-center justify-center bg-forestlt/20">
          <span class="text-forestdk/40 text-sm">Aucune image</span>
        </div>
        {% endif %}

        <label for="image"
               class="flex items-center gap-3 w-full px-4 py-3 rounded-2xl border border-forestlt bg-white cursor-pointer hover:bg-forestlt/30 transition-colors group">
          <svg viewBox="0 0 24 24" class="w-5 h-5 text-forest/60 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
          </svg>
          <span class="text-[15px] text-forestdk/60 group-hover:text-forestdk transition-colors" id="image-label">
            {{ destination.imageName ? 'Remplacer l\'image…' : 'Choisir une image…' }}
          </span>
        </label>
        <input type="file" id="image" name="image" accept="image/*" class="sr-only"
               onchange="document.getElementById('image-label').textContent = this.files[0]?.name ?? '{{ destination.imageName ? 'Remplacer l\'image…' : 'Choisir une image…' }}'">
        <p class="mt-1.5 text-xs text-forestdk/40">JPG, PNG, WebP — max 5 Mo. Laissez vide pour conserver l'image actuelle.</p>
      </div>

      <div class="flex flex-wrap gap-3 pt-2">
        <button type="submit" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-amber text-white font-semibold hover:bg-[#a4660f] transition-colors text-[15px]">
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          Enregistrer les modifications
        </button>
        <a href="{{ path('destination_show', {id: destination.id}) }}" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-forestlt text-forestdk font-semibold hover:bg-forestlt transition-colors text-[15px]">
          Annuler
        </a>
      </div>

    </form>
  </div>
</div>
{% endblock %}
