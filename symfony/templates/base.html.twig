<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}TravelDock{% endblock %}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              forest:   '#3B6D11',
              forestlt: '#EAF3DE',
              forestdk: '#27500A',
              amber:    '#BA7517',
              amberlt:  '#FAEEDA',
            },
            fontFamily: {
              display: ['"Bricolage Grotesque"', 'system-ui', 'sans-serif'],
              sans:    ['"Plus Jakarta Sans"', 'system-ui', 'sans-serif'],
            },
            boxShadow: {
              soft: '0 14px 40px -12px rgba(39,80,10,0.18)',
              lift: '0 24px 60px -18px rgba(39,80,10,0.30)',
            },
          },
        },
      };
    </script>
    <style>
      html { scroll-behavior: smooth; }
      body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; }
      h1, h2, h3, .font-display { font-family: 'Bricolage Grotesque', system-ui, sans-serif; }
      .fade-up { opacity: 0; transform: translateY(22px); transition: opacity .7s ease, transform .7s ease; }
      .fade-up.in { opacity: 1; transform: none; }
      .img-ph {
        background-color: #EAF3DE;
        background-image: repeating-linear-gradient(135deg, #dfeccc 0 12px, #eaf3de 12px 24px);
      }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-white text-forestdk antialiased">

  <!-- NAVBAR -->
  <header class="sticky top-0 z-50 bg-white/85 backdrop-blur-md border-b border-forestlt">
    <nav class="mx-auto max-w-7xl px-5 sm:px-8 h-[72px] flex items-center justify-between">
      <a href="{{ path('app_home') }}" aria-label="TravelDock — accueil">
        <img src="{{ asset('images/logo.png') }}" alt="TravelDock" class="h-10 w-auto">
      </a>

      <ul class="hidden md:flex items-center gap-8 text-[15px] font-medium text-forestdk/80">
        <li><a href="{{ path('travel_index') }}" class="hover:text-forest transition-colors">Voyages</a></li>
        <li><a href="{{ path('destination_index') }}" class="hover:text-forest transition-colors">Destinations</a></li>
        <li><a href="{{ path('booking_index') }}" class="hover:text-forest transition-colors">Réservations</a></li>
      </ul>

      <div class="flex items-center gap-3">
        <a href="{{ path('destination_new') }}" class="hidden lg:inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-forestlt text-forest text-[14px] font-semibold hover:bg-forestlt transition-colors">
          + Destination
        </a>
        <a href="{{ path('travel_new') }}" class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-forest text-white text-[15px] font-semibold shadow-soft hover:bg-forestdk transition-colors">
          Nouveau voyage
        </a>
        <button id="burger" class="md:hidden grid place-items-center w-10 h-10 rounded-lg border border-forestlt text-forest" aria-label="Menu">
          <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </button>
      </div>
    </nav>

    <div id="mobileMenu" class="md:hidden hidden border-t border-forestlt bg-white px-5 py-4">
      <div class="flex flex-col gap-1 text-[15px] font-medium text-forestdk/85">
        <a href="{{ path('travel_index') }}" class="py-2.5 border-b border-forestlt/50">Voyages</a>
        <a href="{{ path('destination_index') }}" class="py-2.5 border-b border-forestlt/50">Destinations</a>
        <a href="{{ path('booking_index') }}" class="py-2.5 border-b border-forestlt/50">Réservations</a>
        <a href="{{ path('destination_new') }}" class="py-2.5 border-b border-forestlt/50">+ Nouvelle destination</a>
        <a href="{{ path('travel_new') }}" class="mt-3 text-center px-5 py-3 rounded-full bg-forest text-white font-semibold">Nouveau voyage</a>
      </div>
    </div>
  </header>

  <!-- FLASH MESSAGES -->
  {% if app.flashes|length > 0 %}
  <div class="mx-auto max-w-7xl px-5 sm:px-8 mt-4 space-y-2">
    {% for label, messages in app.flashes %}
      {% for message in messages %}
        <div class="flex items-center justify-between gap-4 px-5 py-3.5 rounded-2xl border
          {% if label == 'success' %}bg-forestlt text-forestdk border-forest/20
          {% elseif label == 'error' or label == 'danger' %}bg-red-50 text-red-800 border-red-200
          {% elseif label == 'warning' %}bg-amberlt text-amber border-amber/30
          {% else %}bg-blue-50 text-blue-800 border-blue-200{% endif %}">
          <span class="text-[15px]">{{ message }}</span>
          <button onclick="this.parentElement.remove()" class="shrink-0 text-xl leading-none opacity-50 hover:opacity-100 transition-opacity">&times;</button>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
  {% endif %}

  {% block body %}{% endblock %}

  <!-- FOOTER -->
  <footer class="bg-forestdk text-white mt-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-8 py-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10">
        <div class="col-span-2">
          <a href="{{ path('app_home') }}" class="flex items-center" aria-label="TravelDock — accueil">
            <svg viewBox="0 0 188 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-[42px] w-auto">
              <!-- Badge translucide sur fond sombre -->
              <rect x="4" y="4" width="40" height="40" rx="11" fill="white" fill-opacity="0.10"/>
              <rect x="4" y="4" width="40" height="20" rx="11" fill="white" fill-opacity="0.06"/>
              <circle cx="24" cy="24" r="13" stroke="white" stroke-opacity="0.15" stroke-width="1" fill="none"/>
              <!-- Aiguille N-S -->
              <path d="M24 10 L28.5 24 L19.5 24 Z" fill="white"/>
              <path d="M24 38 L28.5 24 L19.5 24 Z" fill="#F0B429" fill-opacity="0.80"/>
              <!-- Axe E-O -->
              <path d="M10 24 L24 20.5 L38 24 L24 27.5 Z" fill="white" fill-opacity="0.18"/>
              <!-- Pivot central -->
              <circle cx="24" cy="24" r="3" fill="#BA7517"/>
              <circle cx="24" cy="24" r="1.5" fill="white" fill-opacity="0.55"/>
              <!-- Texte footer : Travel=blanc, Dock=amber -->
              <text y="33" font-family="'Bricolage Grotesque',system-ui,sans-serif" font-weight="800" font-size="23" letter-spacing="-0.6">
                <tspan x="56" fill="white">Travel</tspan><tspan fill="#BA7517">Dock</tspan>
              </text>
            </svg>
          </a>
          <p class="mt-4 text-white/55 text-[15px] leading-relaxed max-w-xs">Application de gestion de voyages construite avec Symfony 7 & PHP 8.3.</p>
        </div>

        <div>
          <h4 class="font-display font-bold text-[15px] mb-4">Navigation</h4>
          <ul class="space-y-2.5 text-white/55 text-[15px]">
            <li><a href="{{ path('travel_index') }}" class="hover:text-amber transition-colors">Voyages</a></li>
            <li><a href="{{ path('destination_index') }}" class="hover:text-amber transition-colors">Destinations</a></li>
            <li><a href="{{ path('booking_index') }}" class="hover:text-amber transition-colors">Réservations</a></li>
          </ul>
        </div>

        <div>
          <h4 class="font-display font-bold text-[15px] mb-4">Actions</h4>
          <ul class="space-y-2.5 text-white/55 text-[15px]">
            <li><a href="{{ path('travel_new') }}" class="hover:text-amber transition-colors">Nouveau voyage</a></li>
            <li><a href="{{ path('destination_new') }}" class="hover:text-amber transition-colors">Nouvelle destination</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-14 pt-7 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4 text-white/45 text-sm">
        <p>© {{ "now"|date("Y") }} TravelDock — Projet Symfony 7</p>
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('burger').addEventListener('click', () => {
      document.getElementById('mobileMenu').classList.toggle('hidden');
    });
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.fade-up').forEach(el => io.observe(el));
  </script>
  {% block javascripts %}{% endblock %}
</body>
</html>
