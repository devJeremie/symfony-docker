{% extends 'base.html.twig' %}
{% block title %}Réservation #{{ booking.id }} - TravelDock{% endblock %}

{% block body %}
<div class="mx-auto max-w-7xl px-5 sm:px-8 py-10">

  <!-- Header -->
  <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
    <div>
      <span class="text-amber font-semibold text-sm uppercase tracking-[0.18em]">Gestion</span>
      <h1 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mt-1">
        Réservation <span class="text-forestdk/40 font-mono text-2xl">#{{ booking.id }}</span>
      </h1>
    </div>
    <span class="inline-block px-3.5 py-1.5 rounded-full text-sm font-semibold
      {% if booking.status == 'confirmed' %}bg-forest/15 text-forest
      {% elseif booking.status == 'pending' %}bg-amberlt text-amber
      {% else %}bg-red-100 text-red-600{% endif %}">
      {% if booking.status == 'confirmed' %}Confirmée
      {% elseif booking.status == 'pending' %}En attente
      {% else %}Annulée{% endif %}
    </span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

    <!-- Main info -->
    <div class="lg:col-span-2 space-y-6">

      <!-- Traveler info -->
      <div class="bg-white rounded-3xl border border-forestlt shadow-soft p-6">
        <h2 class="font-display text-lg font-bold mb-5 flex items-center gap-2">
          <svg viewBox="0 0 24 24" class="w-5 h-5 text-forest" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
          Informations du voyageur
        </h2>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-forestlt/30 rounded-2xl px-4 py-3">
            <dt class="text-xs font-semibold text-forestdk/50 uppercase tracking-wide mb-1">Nom complet</dt>
            <dd class="font-semibold text-forestdk">{{ booking.fullName }}</dd>
          </div>
          <div class="bg-forestlt/30 rounded-2xl px-4 py-3">
            <dt class="text-xs font-semibold text-forestdk/50 uppercase tracking-wide mb-1">Email</dt>
            <dd class="text-forestdk">{{ booking.email }}</dd>
          </div>
          <div class="bg-forestlt/30 rounded-2xl px-4 py-3">
            <dt class="text-xs font-semibold text-forestdk/50 uppercase tracking-wide mb-1">Téléphone</dt>
            <dd class="text-forestdk">{{ booking.phone ?? 'Non renseigné' }}</dd>
          </div>
          <div class="bg-forestlt/30 rounded-2xl px-4 py-3">
            <dt class="text-xs font-semibold text-forestdk/50 uppercase tracking-wide mb-1">Personnes</dt>
            <dd class="font-semibold text-forestdk">{{ booking.numberOfPersons }}</dd>
          </div>
          <div class="bg-forestlt/30 rounded-2xl px-4 py-3">
            <dt class="text-xs font-semibold text-forestdk/50 uppercase tracking-wide mb-1">Prix total</dt>
            <dd class="font-display text-2xl font-bold text-forest leading-none">{{ booking.totalPrice }} €</dd>
          </div>
          <div class="bg-forestlt/30 rounded-2xl px-4 py-3">
            <dt class="text-xs font-semibold text-forestdk/50 uppercase tracking-wide mb-1">Réservé le</dt>
            <dd class="text-forestdk">{{ booking.bookedAt|date('d/m/Y à H:i') }}</dd>
          </div>
        </dl>
      </div>

      <!-- Travel info -->
      <div class="bg-white rounded-3xl border border-forestlt shadow-soft p-6">
        <h2 class="font-display text-lg font-bold mb-5 flex items-center gap-2">
          <svg viewBox="0 0 24 24" class="w-5 h-5 text-forest" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          Voyage réservé
        </h2>
        <a href="{{ path('travel_show', {id: booking.travel.id}) }}" class="flex items-center justify-between gap-4 p-4 bg-forestlt/30 rounded-2xl hover:bg-forestlt transition-colors group">
          <div>
            <h3 class="font-semibold text-forestdk group-hover:text-forest transition-colors">{{ booking.travel.title }}</h3>
            <div class="flex flex-wrap gap-3 mt-2 text-sm text-forestdk/55">
              <span class="flex items-center gap-1">
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                {{ booking.travel.destination }}
              </span>
              <span class="flex items-center gap-1">
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
                {{ booking.travel.departureDate|date('d/m/Y') }} → {{ booking.travel.returnDate|date('d/m/Y') }}
              </span>
              <span class="flex items-center gap-1">
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
                {{ booking.travel.duration }} jours
              </span>
            </div>
          </div>
          <svg viewBox="0 0 24 24" class="w-4 h-4 text-forest/40 group-hover:text-forest transition-colors shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
        </a>
      </div>

    </div>

    <!-- Actions sidebar -->
    <div>
      <div class="bg-white rounded-3xl border border-forestlt shadow-soft p-6 sticky top-24">
        <h3 class="font-display font-bold text-[15px] mb-4">Actions</h3>
        <div class="flex flex-col gap-3">

          {% if booking.status == 'pending' %}
          <form action="{{ path('booking_confirm', {id: booking.id}) }}" method="post">
            <button type="submit" class="flex items-center justify-center gap-2 w-full px-5 py-2.5 rounded-full bg-forest text-white font-semibold hover:bg-forestdk transition-colors text-[15px] shadow-soft">
              <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 15 9 12"></polyline></svg>
              Confirmer
            </button>
          </form>
          {% endif %}

          {% if booking.status != 'cancelled' %}
          <form action="{{ path('booking_cancel', {id: booking.id}) }}" method="post" onsubmit="return confirm('Annuler cette réservation ?')">
            <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ booking.id) }}">
            <button type="submit" class="flex items-center justify-center gap-2 w-full px-5 py-2.5 rounded-full bg-red-500 text-white font-semibold hover:bg-red-600 transition-colors text-[15px]">
              <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M15 9l-6 6M9 9l6 6"></path></svg>
              Annuler la réservation
            </button>
          </form>
          {% endif %}

          <a href="{{ path('booking_index') }}" class="flex items-center justify-center gap-2 px-5 py-2.5 rounded-full border border-forestlt text-forestdk font-semibold hover:bg-forestlt transition-colors text-[15px]">
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"></path></svg>
            Retour aux réservations
          </a>
        </div>
      </div>
    </div>

  </div>
</div>
{% endblock %}
