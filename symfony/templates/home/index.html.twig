{% extends 'base.html.twig' %}

{% block title %}TravelDock — Explorez le monde, vivez l'aventure{% endblock %}

{% block body %}

{# Mapping destination name → travel card image #}
{% set travelImageMap = {
  'Paris': 'paris.png',
  'Marrakech': 'marocco.png',
  'Tokyo': 'japan.png',
  'Bali': 'Bali.png',
  'New York': 'newYork.png'
} %}

{# Mapping destination name → vignette image #}
{% set vignetteMap = {
  'Bali': 'vignetteBali.png',
  'Marrakech': 'vignetteMarrakech.png',
  'New York': 'vignetteNewYork.png',
  'Paris': 'vignetteParis.png',
  'Tokyo': 'vignetteTokyo.png'
} %}

  <!-- ===== HERO ===== -->
  <section class="relative">
    <div class="relative min-h-[580px] lg:min-h-[640px] flex items-center">
      <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('{{ asset('images/HeroSection.png') }}')"></div>
      <div class="absolute inset-0 bg-gradient-to-br from-forestdk/90 via-forestdk/65 to-forest/60"></div>

      <div class="relative mx-auto max-w-7xl w-full px-5 sm:px-8 pt-16 pb-44 lg:pb-52">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/15 backdrop-blur-sm border border-white/25 text-white text-sm font-medium mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-amber inline-block"></span>
          Agence de voyage &amp; aventures sur mesure
        </span>
        <h1 class="font-display text-white font-bold leading-[1.04] tracking-tight text-[44px] sm:text-6xl lg:text-7xl max-w-3xl">
          Explorez le monde,<br class="hidden sm:block"> vivez l'aventure
        </h1>
        <p class="mt-6 text-white/85 text-lg sm:text-xl max-w-xl leading-relaxed">
          Des voyages soigneusement imaginés, des destinations qui marquent une vie. Votre prochain départ commence ici.
        </p>
        <div class="mt-9 flex flex-wrap gap-4">
          <a href="{{ path('travel_index') }}" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-amber text-white font-semibold text-[16px] shadow-lift hover:bg-[#a4660f] transition-colors">
            Découvrir nos voyages
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
          </a>
          <a href="{{ path('destination_index') }}" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-white/10 border border-white/40 text-white font-semibold text-[16px] backdrop-blur-sm hover:bg-white/20 transition-colors">
            Toutes les destinations
          </a>
        </div>
      </div>
    </div>

    <!-- SEARCH BAR -->
    <div class="relative -mt-28 lg:-mt-24 z-20 mx-auto max-w-6xl px-5 sm:px-8">
      <div class="bg-white rounded-3xl shadow-lift border border-forestlt p-3 sm:p-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-2 md:gap-0 md:divide-x md:divide-forestlt">
          <label class="px-4 py-3 rounded-2xl hover:bg-forestlt/40 transition-colors cursor-pointer">
            <span class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-forest/70">
              <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              Destination
            </span>
            <input type="text" placeholder="Où partez-vous ?" class="mt-1 w-full bg-transparent text-[15px] font-medium text-forestdk placeholder:text-forestdk/40 focus:outline-none">
          </label>
          <label class="px-4 py-3 rounded-2xl hover:bg-forestlt/40 transition-colors cursor-pointer">
            <span class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-forest/70">
              <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
              Date de départ
            </span>
            <input type="text" onfocus="this.type='date'" onblur="if(!this.value)this.type='text'" placeholder="Choisir une date" class="mt-1 w-full bg-transparent text-[15px] font-medium text-forestdk placeholder:text-forestdk/40 focus:outline-none">
          </label>
          <div class="flex items-center gap-2 px-2">
            <label class="flex-1 px-2 py-3 rounded-2xl hover:bg-forestlt/40 transition-colors cursor-pointer">
              <span class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-forest/70">
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
                Voyageurs
              </span>
              <select class="mt-1 w-full bg-transparent text-[15px] font-medium text-forestdk focus:outline-none cursor-pointer">
                <option>1 voyageur</option>
                <option>2 voyageurs</option>
                <option>3 voyageurs</option>
                <option>4 voyageurs +</option>
              </select>
            </label>
            <button class="shrink-0 grid place-items-center w-14 h-14 rounded-2xl bg-forest text-white shadow-soft hover:bg-forestdk transition-colors" aria-label="Rechercher">
              <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VOYAGES À VENIR ===== -->
  {% if travels is not empty %}
  <section id="voyages" class="bg-forestlt/40 pt-32 pb-24">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-10">
        <div>
          <span class="text-amber font-semibold text-sm uppercase tracking-[0.18em]">Prochains départs</span>
          <h2 class="font-display text-4xl sm:text-5xl font-bold tracking-tight mt-3">Voyages à venir</h2>
        </div>
        <a href="{{ path('travel_index') }}" class="hidden sm:inline-flex items-center gap-2 text-forest font-semibold hover:gap-3 transition-all">
          Tous les voyages
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for travel in travels %}
        {% set travelImg = travelImageMap[travel.destination.name] ?? null %}
        <article class="fade-up group bg-white rounded-3xl overflow-hidden shadow-soft border border-forestlt hover:shadow-lift transition-shadow">
          <div class="relative h-52 overflow-hidden flex items-end">
            {% if travelImg %}
              <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('{{ asset('images/' ~ travelImg) }}')"></div>
            {% else %}
              <div class="absolute inset-0 img-ph"></div>
            {% endif %}
            <div class="absolute inset-0 bg-gradient-to-t from-forestdk/70 to-transparent"></div>
            <div class="relative p-5">
              <span class="px-3 py-1 rounded-full bg-forest text-white text-xs font-semibold shadow-soft">
                {{ travel.destination }}
              </span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-display text-xl font-bold leading-snug">{{ travel.title }}</h3>
            {% if travel.description %}
            <p class="mt-2 text-forestdk/60 text-sm leading-relaxed line-clamp-2">{{ travel.description|slice(0, 120) }}{% if travel.description|length > 120 %}…{% endif %}</p>
            {% endif %}
            <div class="flex flex-wrap items-center gap-3 mt-4 text-forestdk/55 text-sm">
              <span class="flex items-center gap-1.5">
                <svg viewBox="0 0 24 24" class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
                {{ travel.departureDate|date('d/m/Y') }} → {{ travel.returnDate|date('d/m/Y') }}
              </span>
              <span class="flex items-center gap-1.5">
                <svg viewBox="0 0 24 24" class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
                {{ travel.duration }} jours
              </span>
              <span class="flex items-center gap-1.5">
                <svg viewBox="0 0 24 24" class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
                {{ travel.availableSeats }} places restantes
              </span>
            </div>
            <div class="flex items-end justify-between mt-5 pt-5 border-t border-forestlt">
              <div>
                <span class="text-xs text-forestdk/45">À partir de</span>
                <p class="font-display text-2xl font-bold text-forest leading-none mt-0.5">
                  {{ travel.price }}€<span class="text-sm font-medium text-forestdk/45"> /pers.</span>
                </p>
              </div>
              <a href="{{ path('travel_show', {id: travel.id}) }}" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-amber text-white text-sm font-semibold hover:bg-[#a4660f] transition-colors">
                Voir
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
              </a>
            </div>
          </div>
        </article>
        {% endfor %}
      </div>
    </div>
  </section>
  {% else %}
  <section class="pt-32 pb-12 mx-auto max-w-7xl px-5 sm:px-8">
    <div class="flex flex-col items-center justify-center py-16 text-center bg-forestlt/30 rounded-3xl border border-forestlt">
      <svg viewBox="0 0 24 24" class="w-12 h-12 text-forest/40 mb-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
      <p class="text-forestdk/60 text-lg mb-4">Aucun voyage disponible pour le moment.</p>
      <a href="{{ path('travel_new') }}" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-forest text-white font-semibold hover:bg-forestdk transition-colors">
        + Créer un voyage
      </a>
    </div>
  </section>
  {% endif %}

  <!-- ===== DESTINATIONS ===== -->
  {% if destinations is not empty %}
  <section id="destinations" class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-10">
        <div>
          <span class="text-amber font-semibold text-sm uppercase tracking-[0.18em]">Destinations populaires</span>
          <h2 class="font-display text-4xl sm:text-5xl font-bold tracking-tight mt-3">Là où l'envie de partir vous mène</h2>
        </div>
        <a href="{{ path('destination_index') }}" class="hidden sm:inline-flex items-center gap-2 text-forest font-semibold hover:gap-3 transition-all">
          Toutes les destinations
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-5">
        {% for destination in destinations %}
        {% set vignetteImg = vignetteMap[destination.name] ?? null %}
        <a href="{{ path('destination_show', {id: destination.id}) }}" class="fade-up group block">
          <article class="relative rounded-3xl overflow-hidden min-h-[160px] sm:min-h-[200px] shadow-soft">
            {% if vignetteImg %}
              <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('{{ asset('images/' ~ vignetteImg) }}')"></div>
            {% else %}
              <div class="absolute inset-0 img-ph"></div>
            {% endif %}
            <div class="absolute inset-0 bg-gradient-to-t from-forestdk/80 via-forestdk/20 to-transparent group-hover:from-forestdk/90 transition-all duration-500"></div>
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <svg viewBox="0 0 24 24" class="w-8 h-8 text-white/70" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
            </div>
            <div class="absolute bottom-0 p-4 sm:p-5">
              <h3 class="font-display text-white text-base sm:text-lg font-bold leading-tight">{{ destination.name }}</h3>
              <p class="text-white/70 text-xs mt-0.5">{{ destination.country }}</p>
              {% if destination.iataCode %}
              <span class="inline-block mt-1.5 px-2 py-0.5 rounded bg-white/15 text-white/80 text-[11px] font-mono tracking-wider">{{ destination.iataCode }}</span>
              {% endif %}
            </div>
          </article>
        </a>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

{% endblock %}
